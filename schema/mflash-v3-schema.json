{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mflash.dev/schema/mflash-v3-schema.json",
  "title": "mflash v3",
  "description": "Schema for mflash v3 deck JSON, used by raw .mflash.json files and deck.json inside packaged .mflash archives.",
  "type": "object",
  "additionalProperties": true,
  "required": ["format", "version", "id", "title", "cards"],
  "properties": {
    "format": {
      "const": "mflash"
    },
    "version": {
      "type": "integer",
      "const": 3
    },
    "id": {
      "$ref": "#/$defs/uuid",
      "description": "Stable deck UUID used for progress files, syncing, references, and app metadata. Should not contain personally identifying information."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "snippet": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "default_term_lang": {
      "type": "string",
      "description": "Default BCP 47 language tag for card terms when a card does not specify term_lang."
    },
    "default_def_lang": {
      "type": "string",
      "description": "Default BCP 47 language tag for card definitions when a card does not specify def_lang."
    },
    "deck_tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "cover": {
      "$ref": "#/$defs/media"
    },
    "cards": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/card"
      },
      "default": []
    },
    "extensions": {
      "$ref": "#/$defs/extensions"
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true,
      "description": "Namespaced extension data for plugins, experiments, or application-specific metadata."
    },
    "card": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "kind"],
      "properties": {
        "id": {
          "$ref": "#/$defs/uuid",
          "description": "Stable card UUID used for progress tracking, syncing, media references, review history, and app metadata."
        },
        "kind": {
          "type": "string",
          "enum": ["basic", "image_occlusion", "listening", "media_prompt"]
        },
        "prompt": {
          "type": "string"
        },
        "answer": {
          "type": "string"
        },
        "term": {
          "type": "string"
        },
        "definition": {
          "type": "string"
        },
        "term_lang": {
          "type": "string",
          "description": "BCP 47 language tag for the term."
        },
        "def_lang": {
          "type": "string",
          "description": "BCP 47 language tag for the definition."
        },
        "phonetic": {
          "type": "string"
        },
        "part_of_speech": {
          "type": "string"
        },
        "lexical": {
          "$ref": "#/$defs/lexical"
        },
        "notes": {
          "type": "string"
        },
        "hyperlink": {
          "type": "string",
          "format": "uri"
        },
        "media": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/media"
          },
          "default": []
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "examples": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/example"
          },
          "default": []
        },
        "occlusion": {
          "$ref": "#/$defs/occlusion"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "basic"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["term", "definition"]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "image_occlusion"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["occlusion"]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "listening"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["media", "answer"]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "media_prompt"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["media", "answer"]
          }
        }
      ]
    },
    "media": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "src"],
      "properties": {
        "id": {
          "$ref": "#/$defs/uuid"
        },
        "type": {
          "type": "string",
          "enum": ["image", "audio", "video", "gif", "document", "other"]
        },
        "role": {
          "type": "string",
          "enum": [
            "cover",
            "illustration",
            "prompt_image",
            "answer_image",
            "prompt_video",
            "answer_video",
            "prompt_animation",
            "answer_animation",
            "term_pronunciation",
            "definition_pronunciation",
            "question_audio",
            "answer_audio",
            "example_audio",
            "explanation_audio",
            "occlusion_image",
            "source_document",
            "supplement"
          ]
        },
        "src": {
          "type": "string",
          "minLength": 1
        },
        "alt": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "lang": {
          "type": "string",
          "description": "BCP 47 language tag for this media item when relevant."
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "lexical": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "etymology": {
          "type": "string"
        },
        "morphology": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/morpheme"
          },
          "default": []
        },
        "ipa": {
          "type": "string"
        },
        "phonetic": {
          "type": "string"
        },
        "romanization": {
          "type": "string"
        },
        "register": {
          "type": "string"
        },
        "usage_note": {
          "type": "string"
        },
        "related_terms": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "language": {
          "type": "string",
          "description": "BCP 47 language tag for the lexical metadata."
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "morpheme": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "form": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "prefix",
            "root",
            "stem",
            "suffix",
            "infix",
            "circumfix",
            "combining_form",
            "particle",
            "other"
          ]
        },
        "meaning": {
          "type": "string"
        },
        "origin": {
          "type": "string"
        },
        "lang": {
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "example": {
      "type": "object",
      "additionalProperties": true,
      "required": ["text"],
      "properties": {
        "id": {
          "$ref": "#/$defs/uuid"
        },
        "text": {
          "type": "string"
        },
        "translation": {
          "type": "string"
        },
        "lang": {
          "type": "string",
          "description": "BCP 47 language tag for the example text."
        },
        "translation_lang": {
          "type": "string",
          "description": "BCP 47 language tag for the example translation."
        },
        "media": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/media"
          },
          "default": []
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "occlusion": {
      "type": "object",
      "additionalProperties": true,
      "required": ["image", "masks"],
      "properties": {
        "image": {
          "$ref": "#/$defs/media"
        },
        "masks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/occlusion_mask"
          },
          "default": []
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "occlusion_mask": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "shape", "answer"],
      "properties": {
        "id": {
          "$ref": "#/$defs/uuid"
        },
        "shape": {
          "type": "string",
          "enum": ["rect", "ellipse", "polygon"]
        },
        "x": {
          "$ref": "#/$defs/normalized_number"
        },
        "y": {
          "$ref": "#/$defs/normalized_number"
        },
        "w": {
          "$ref": "#/$defs/normalized_number"
        },
        "h": {
          "$ref": "#/$defs/normalized_number"
        },
        "points": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/point"
          },
          "minItems": 3
        },
        "answer": {
          "type": "string",
          "minLength": 1
        },
        "hint": {
          "type": "string"
        },
        "explanation": {
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "shape": {
                "const": "rect"
              }
            },
            "required": ["shape"]
          },
          "then": {
            "required": ["x", "y", "w", "h"]
          }
        },
        {
          "if": {
            "properties": {
              "shape": {
                "const": "ellipse"
              }
            },
            "required": ["shape"]
          },
          "then": {
            "required": ["x", "y", "w", "h"]
          }
        },
        {
          "if": {
            "properties": {
              "shape": {
                "const": "polygon"
              }
            },
            "required": ["shape"]
          },
          "then": {
            "required": ["points"]
          }
        }
      ]
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": {
          "$ref": "#/$defs/normalized_number"
        },
        "y": {
          "$ref": "#/$defs/normalized_number"
        }
      }
    },
    "normalized_number": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}