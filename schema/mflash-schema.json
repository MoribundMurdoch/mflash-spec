{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "mflash v2",
  "description": "Schema for mflash v2 deck JSON, used by raw .mflash.json files and deck.json inside packaged .mflash archives.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "format",
    "version",
    "id",
    "title",
    "cards"
  ],
  "properties": {
    "format": {
      "const": "mflash"
    },
    "version": {
      "type": "integer",
      "const": 2
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable deck identifier used for progress files, syncing, references, and app metadata. Should not contain personally identifying information."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "snippet": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Optional ISO 8601 timestamp for when the deck was created. Applications must not require this field."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Optional ISO 8601 timestamp for when the deck content was last meaningfully updated. Applications must not require this field."
    },
    "default_term_lang": {
      "type": "string",
      "description": "Default BCP 47 language tag for card terms when a card does not specify term_lang."
    },
    "default_def_lang": {
      "type": "string",
      "description": "Default BCP 47 language tag for card definitions when a card does not specify def_lang."
    },
    "deck_tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "cover_media": {
      "type": "string"
    },
    "cards": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/card"
      },
      "default": []
    }
  },
  "$defs": {
    "card": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "term",
        "definition"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable card identifier used for progress tracking, syncing, media references, and app metadata. Should not contain personally identifying information."
        },
        "term": {
          "type": "string"
        },
        "definition": {
          "type": "string"
        },
        "term_lang": {
          "type": "string",
          "description": "BCP 47 language tag for the term."
        },
        "def_lang": {
          "type": "string",
          "description": "BCP 47 language tag for the definition."
        },
        "phonetic": {
          "type": "string"
        },
        "part_of_speech": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "hyperlink": {
          "type": "string",
          "format": "uri"
        },
        "media": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/media"
              }
            }
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "examples": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "$ref": "#/$defs/example"
              }
            ]
          },
          "default": []
        }
      }
    },
    "media": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type",
        "src"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "image",
            "audio",
            "video",
            "gif",
            "other"
          ]
        },
        "src": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "example": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string"
        },
        "translation": {
          "type": "string"
        },
        "lang": {
          "type": "string",
          "description": "BCP 47 language tag for the example text."
        },
        "translation_lang": {
          "type": "string",
          "description": "BCP 47 language tag for the example translation."
        }
      }
    }
  }
}